# ===================================================================
# dbt Docs Hub — environment template
# ===================================================================
# Copy to .env and adjust the values to match YOUR platform.
# The only one you MUST set yourself is OAUTH2_PROXY_COOKIE_SECRET.
# Generate it with:
#   openssl rand -base64 32 | tr -- '+/' '-_' | tr -d '\n'

OAUTH2_PROXY_COOKIE_SECRET=

# --- Artifact Store (S3-compatible bucket holding <project>/manifest.json …) ---
# Examples: MinIO running in your stack, AWS S3, Ceph, GCS via interop.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio-admin
MINIO_SECRET_KEY=minio-secret-change-me
MINIO_BUCKET=dbt-docs

# --- Identity Provider (OIDC issuer emitting a JWT with a `groups` claim) ---
# Examples: Keycloak, Auth0, Okta, Google Workspace.
KEYCLOAK_URL=http://keycloak.local:8090
KEYCLOAK_REALM=reborn
KEYCLOAK_CLIENT_ID=dbt-docs-hub
KEYCLOAK_CLIENT_SECRET=dbt-docs-hub-secret-change-me

# --- Policy Engine (any backend honouring the dbtdocs HTTP contract) ---
# Reference impl: OPA serving the Rego bundle from examples/opa-policies/.
# Wire contract: POST /v1/data/dbtdocs/{allow,column_visible}
#                body {"input": {...}} → {"result": bool}.
POLICY_ENGINE_URL=http://opa:8181

# --- Metadata Indexer (sync interval between Artifact Store scans) ---
SYNC_INTERVAL=60

# --- Network ---
# Default: this stack creates its own bridge network 'dbt-docs-hub-net'.
# To attach to an existing network (e.g. the Docker network your IdP /
# Artifact Store / Policy Engine already share), set both:
#   HUB_NETWORK_NAME=<your-existing-network>
#   HUB_NETWORK_EXTERNAL=true
HUB_NETWORK_NAME=dbt-docs-hub-net
HUB_NETWORK_EXTERNAL=false
