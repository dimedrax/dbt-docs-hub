# Reborn DataOps Platform — generated by the Metadata Indexer.
# DO NOT EDIT BY HAND. Regenerated each sync cycle.

server {
    listen 80;
    server_name _;

    # Trust X-Forwarded-* headers from oauth2-proxy.
    real_ip_header X-Forwarded-For;
    set_real_ip_from 0.0.0.0/0;

    root /usr/share/nginx/html;
    index index.html;

    # ---- Defaults shared by every proxy_pass below ----
    proxy_http_version 1.1;
    proxy_set_header Host                $host;
    proxy_set_header X-Real-IP           $remote_addr;
    proxy_set_header X-Forwarded-For     $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto   $scheme;
    proxy_set_header Authorization       $http_authorization;

    # ---- Portal home page (React SPA) ----
    location = / {
        try_files /index.html =404;
    }

    # ---- Health endpoint (oauth2-proxy skips auth on /health) ----
    location = /health {
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }

    # ---- Catalog SPA shell (BrowserRouter fallback target) ----
    location = /catalog.html {
        try_files /catalog.html =404;
    }

    # ---- Filtering API: OPA-filtered JSON ----
    location /api/ {
        proxy_pass {{ filtering_api_upstream }};
    }

{% for project in projects %}
    # ===== {{ project.name }} =====

    # OPA-filtered manifest/catalog (used by both the Reborn SPA and the
    # native dbt-docs SPA inside the lineage iframe).
    location = /{{ project.name }}/manifest.json     { proxy_pass {{ filtering_api_upstream }}/{{ project.name }}/manifest.json; }
    location = /{{ project.name }}/catalog.json      { proxy_pass {{ filtering_api_upstream }}/{{ project.name }}/catalog.json; }
    location = /{{ project.name }}/_dbt/manifest.json { proxy_pass {{ filtering_api_upstream }}/{{ project.name }}/manifest.json; }
    location = /{{ project.name }}/_dbt/catalog.json  { proxy_pass {{ filtering_api_upstream }}/{{ project.name }}/catalog.json; }

    # Native dbt-docs SPA (lineage iframe target). The sub_filter injects a
    # <base> so dbt's absolute paths resolve under /<project>/_dbt/ and a
    # Reborn navbar so a direct visit still feels branded.
    location /{{ project.name }}/_dbt/ {
        alias /usr/share/nginx/html/{{ project.name }}/_dbt/;
        index index.html;
        try_files $uri $uri/ /{{ project.name }}/_dbt/index.html;

        gzip off;
        sub_filter_once off;
        sub_filter_types text/html;

        sub_filter '<head>' '<head><base href="/{{ project.name }}/_dbt/">';

        sub_filter '</head>'
        '<style>
          html { scroll-padding-top: 44px; }
          body { padding-top: 44px !important; }
          .app-header.app-navbar, nav.app-navbar, header.app-header { top: 44px !important; }
          #reborn-nav { position: fixed; top: 0; left: 0; right: 0; height: 44px;
            background: #1B2FCC; display: flex; align-items: center;
            padding: 0 20px; gap: 14px; z-index: 99999;
            font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
            box-shadow: 0 2px 8px rgba(27,47,204,.4); }
          #reborn-nav a, #reborn-nav span, #reborn-nav div { line-height: 1.2; }
          .rb-back { color: rgba(255,255,255,.85); font-size: 12px;
            text-decoration: none; padding: 5px 11px;
            border: 1px solid rgba(255,255,255,.25); border-radius: 6px;
            font-family: "JetBrains Mono", ui-monospace, monospace; letter-spacing: .02em;
            transition: all .15s; }
          .rb-back:hover { color: #fff; background: rgba(255,255,255,.12); border-color: rgba(255,255,255,.5); }
          .rb-sep { color: rgba(255,255,255,.25); margin: 0 2px; }
          .rb-acorn { display: inline-flex; align-items: center; }
          .rb-proj { color: #fff; font-weight: 600; font-size: 14px; letter-spacing: -.01em; }
          .rb-label { color: rgba(255,255,255,.55); font-size: 10px;
            font-family: "JetBrains Mono", ui-monospace, monospace; letter-spacing: .08em;
            text-transform: uppercase; margin-bottom: 1px; }
        </style></head>';

        sub_filter '</body>'
        '<div id="reborn-nav">
          <a class="rb-back" href="/{{ project.name }}/">&#8592; Catalog</a>
          <span class="rb-sep">|</span>
          <span class="rb-acorn"><svg width="20" height="20" viewBox="0 0 28 28" fill="none"><ellipse cx="14" cy="18" rx="9" ry="10" fill="white"/><ellipse cx="14" cy="10" rx="10" ry="5.5" fill="#B8C4D4"/><circle cx="14" cy="10.5" r="1.5" fill="white"/></svg></span>
          <div>
            <div class="rb-label">dbt-docs native</div>
            <div class="rb-proj">{{ project.name }}</div>
          </div>
        </div></body>';

        proxy_hide_header X-Frame-Options;
    }

    # Reborn catalog SPA — owns every other /{project}/* path.
    location /{{ project.name }}/ {
        try_files $uri /catalog.html;
    }
{% endfor %}
}
